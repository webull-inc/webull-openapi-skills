# Webull OpenAPI Skill Configuration
# Copy this file to .env and fill in your credentials

# ==============================================================================
# Required: Webull API Credentials
# ==============================================================================

# Your Webull App Key from the developer portal
WEBULL_APP_KEY=

# Your Webull App Secret from the developer portal
WEBULL_APP_SECRET=

# ==============================================================================
# Optional: Environment Settings
# ==============================================================================

# API environment: uat (sandbox) or prod (production)
# Default: uat (paper trading — safe for testing)
# Set to 'prod' for live trading (use with caution)
# WEBULL_ENVIRONMENT=uat

# Region ID: us, hk, jp, or sg
# Default: us
# WEBULL_REGION_ID=us
#
# Region examples:
#   Webull US:        WEBULL_REGION_ID=us
#   Webull HK:        WEBULL_REGION_ID=hk
#   Webull Japan:     WEBULL_REGION_ID=jp
#   Webull Singapore: WEBULL_REGION_ID=sg
#
# JP notes:
#   - JP supports stock/ETF market data and stock trading/order management.
#   - Use WEBULL_ENVIRONMENT=uat for sandbox; set prod only for live trading.
#   - JP stock orders require account_tax_type in the order JSON.
#
# SG notes:
#   - SG supports US stock/ETF trading for Singapore-based clients.
#   - Order types: MARKET, LIMIT, STOP_LOSS, STOP_LOSS_LIMIT.
#   - No futures, crypto, options, or event contracts.

# ==============================================================================
# Optional: Risk Control Parameters
# ==============================================================================

# Maximum notional value per order by market currency
# Each market uses its own currency limit:
#   - US market: USD
#   - HK market: HKD
#   - CN market: CNH (China Connect/A-shares)
#   - JP market: JPY

# US market limit in USD (default: 10000)
# WEBULL_MAX_ORDER_NOTIONAL_USD=10000

# HK market limit in HKD (default: 80000)
# WEBULL_MAX_ORDER_NOTIONAL_HKD=80000

# CN market limit in CNH (default: 70000)
# WEBULL_MAX_ORDER_NOTIONAL_CNH=70000

# JP market limit in JPY (default: 1500000)
# WEBULL_MAX_ORDER_NOTIONAL_JPY=1500000

# Maximum quantity per order (shares/contracts)
# Default: 1000
# WEBULL_MAX_ORDER_QUANTITY=1000

# Symbol whitelist (comma-separated, empty = no restriction)
# Example: AAPL,MSFT,GOOGL,AMZN
# WEBULL_SYMBOL_WHITELIST=

# ==============================================================================
# Optional: Audit Logging
# ==============================================================================

# File path for audit logs (in addition to stderr)
# Default: stderr only (no file logging)
# WEBULL_AUDIT_LOG_FILE=

# ==============================================================================
# Optional: Token Storage
# ==============================================================================

# Custom config directory — moves ALL sensitive files out of the project.
# When set, both .env and token storage will be read from this directory:
#   - $WEBULL_CONFIG_DIR/.env        (credentials)
#   - $WEBULL_CONFIG_DIR/conf/       (auth tokens, unless WEBULL_TOKEN_DIR overrides)
#
# IMPORTANT: This variable must be set as a system environment variable (e.g. in
# ~/.zshrc or ~/.bashrc), NOT in a .env file. Setting it inside .env has no effect
# because the code needs to know where to find .env before it can read .env.
#
# Example (add to ~/.zshrc or ~/.bashrc):
#   export WEBULL_CONFIG_DIR=~/.config/webull-skill
#
# Default: project root (sibling of webull_openapi_skills/)
# WEBULL_CONFIG_DIR=

# Directory for storing authentication tokens
# Default: $WEBULL_CONFIG_DIR/conf/ (or <project_root>/conf/ if WEBULL_CONFIG_DIR not set)
# Only needed if you want token storage separate from WEBULL_CONFIG_DIR.
# WEBULL_TOKEN_DIR=

# ==============================================================================
# Optional: SDK Logging
# ==============================================================================

# SDK log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: WARNING
# WEBULL_LOG_LEVEL=WARNING
